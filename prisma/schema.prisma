generator client {
  provider = "prisma-client-js"
  // Remova o engineType se houver, ou deixe como "library" se estiver no Windows
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL") // ADICIONE ESTA LINHA
}

// Seus models (User, Equipamento, etc) continuam abaixo...

model User {
  id        String   @id @default(uuid()) @db.NVarChar(450)
  nome      String     @db.NVarChar(Max)
  sobrenome String     @db.NVarChar(Max)
  email     String     @unique(map: "UQ__User__AB6E6164B6D39C13") @db.NVarChar(450)
  password  String     @db.NVarChar(Max)
  uf        String     @db.NVarChar(Max)
  regional  String     @db.NVarChar(Max)
  role      String     @db.NVarChar(Max)
  ativo     Boolean    @default(true, map: "DF__User__ativo__5EBF139D")
  criadoEm  DateTime   @default(now(), map: "DF__User__criadoEm__5FB337D6")
  inspecoes Inspecao[]
  medidas   Medida[]   @relation("MedidasCriadas")
}

model PontoInstalacao {
  id                 String       @id @default(uuid()) @db.NVarChar(450)
  nome               String       @db.NVarChar(Max)
  uf                 String       @db.NVarChar(Max)
  regional           String       @db.NVarChar(Max)
  base               String       @db.NVarChar(Max)
  qrCode             String       @unique @db.NVarChar(450)
  ativo              Boolean      @default(true)
  
  equipamentoAtualId String?      @unique @db.NVarChar(450)
  equipamentoAtual   Equipamento? @relation(fields: [equipamentoAtualId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  inspecoes          Inspecao[]
}

model AcaoCorretiva {
  id                 String    @id @default(uuid()) @db.NVarChar(450)
  status             String    @default("Em Andamento") @db.NVarChar(Max)
  dataVencimento     DateTime?
  titulo             String    @db.NVarChar(Max)
  descricao          String    @db.NVarChar(Max)
  numNC              String?   @db.NVarChar(Max)
  nomeResponsavel    String    @db.NVarChar(Max)
  emailsCopia        String?   @db.NVarChar(Max)
  criadoEm           DateTime  @default(now())

  // Relacionamentos
  inspecaoId         String    @db.NVarChar(450)
  inspecao           Inspecao  @relation(fields: [inspecaoId], references: [id], onDelete: Cascade)
}

model Equipamento {
  id    String @id @default(uuid()) @db.NVarChar(450)

  // ── Identificação principal ───────────────────────────────────────────────
  // Para extintores, 'codigo' recebe o Nº de Série do Cilindro.
  // Para os demais tipos, recebe o Nº de Série / Patrimônio.
  codigo  String @unique @db.NVarChar(450)

  tipo    String @db.NVarChar(Max)
  status  String @db.NVarChar(Max)
  uf      String @db.NVarChar(Max)

  // ── Descrição livre ───────────────────────────────────────────────────────
  nome    String? @db.NVarChar(Max) // Nome / Descrição informada no cadastro

  // ── Campos específicos do Extintor ────────────────────────────────────────
  extintorClasse  String?   @db.NVarChar(Max)  // ABC, BC, AB, A, D, K ou manual
  extintorCarga   Decimal?  @db.Decimal(8, 2)  // kg
  agente          String?   @db.NVarChar(Max)  // Pó ABC, CO₂, Água etc.
  serieInmetro    String?   @db.NVarChar(450)  // Nº do Selo INMETRO
  serieCilindro   String?   @db.NVarChar(450)  // Nº de Série do Cilindro (= codigo p/ extintores)
  proximaRecarga  DateTime? // Validade da Recarga

  // ── Campos genéricos (demais tipos) ──────────────────────────────────────
  // 'agente' já cobre o campo livre de agente/especificação dos não-extintores

  // ── Campos legados (mantidos para compatibilidade) ────────────────────────
  fabricante      String?   @db.NVarChar(Max)
  modelo          String?   @db.NVarChar(Max)
  capacidade      String?   @db.NVarChar(Max)
  dataFabricacao  DateTime?
  ultimaRecarga   DateTime?
  ultimaInspecao  DateTime?
  proximaInspecao DateTime?

  pontoInstalacao PontoInstalacao?
  inspecoes       Inspecao[]
}


model Inspecao {
  id              String          @id @default(uuid()) @db.NVarChar(450)
  data            DateTime        @default(now())
  status          String          @db.NVarChar(Max)
  respostas       String          @db.NVarChar(Max)
  uf              String          @db.NVarChar(Max)
  regional        String          @db.NVarChar(Max)
  base            String          @db.NVarChar(Max)
  localNome       String          @db.NVarChar(Max)
  
  pontoId         String          @db.NVarChar(450)
  // Adicionado NoAction para evitar caminhos múltiplos de cascata
  ponto           PontoInstalacao @relation(fields: [pontoId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  equipamentoId   String          @db.NVarChar(450)
  // Adicionado NoAction para evitar caminhos múltiplos de cascata
  equipamento     Equipamento     @relation(fields: [equipamentoId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  inspetorId      String          @db.NVarChar(450)
  inspetor        User            @relation(fields: [inspetorId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  acoesCorretivas AcaoCorretiva[]
}
model Medida {
  id        String   @id @default(uuid()) @db.NVarChar(450)
  data          DateTime @default(now(), map: "DF__Medida__data__6D0D32F4")
  colaborador   String   @db.NVarChar(Max)
  matricula     String   @db.NVarChar(Max)
  supervisor    String   @db.NVarChar(Max)
  tipo          String   @db.NVarChar(Max)
  ocorrencia    String   @db.NVarChar(Max)
  medida        String   @db.NVarChar(Max)
  gravidade     String   @db.NVarChar(Max)
  classificacao String   @db.NVarChar(Max)
  status        String   @default("EM ANDAMENTO", map: "DF__Medida__status__6E01572D") @db.NVarChar(Max)
  criadoPorId   String   @db.NVarChar(450)
  criadoPor     User     @relation("MedidasCriadas", fields: [criadoPorId], references: [id], onDelete: Cascade)
  numeroInspecao String?  @db.NVarChar(Max)
  diasSuspensao  Int?
  nomeSupervisor String   @db.NVarChar(Max)
}


model TaxaContato {
  chave        Int      @id
  chapa        String?
  nome         String?
  cpf          String?
  funcao       String?  @map("FUNCAO")
  secao        String?
  codsituacao  String?
  local        String?
  regional     String?
  area         String?
  equipe       String?
  supervisor   String?
  data         String?
  base         String?
  email        String?
  filial       String?

  @@map("taxa de contato")
}